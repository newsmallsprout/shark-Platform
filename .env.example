# =============================================================================
# Shark Platform — Docker Compose 本地联调（复制为 .env 后修改）
#   cp .env.example .env
#   # 必填：至少填写 SHARK_AI_API_KEY（DeepSeek）与 SHARK_EDGE_TOKEN（日志采集）
# =============================================================================

# --- Django ---
DJANGO_SECRET_KEY=dev-local-change-me-use-openssl-rand-hex-32-in-prod
DEBUG=True
ALLOWED_HOSTS=*
PUBLIC_URL=http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Redis / Celery（Compose 内服务名 redis，勿改主机名除非自定义网络）---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TIMEZONE=Asia/Shanghai
AGENT_EVENT_REDIS_URL=redis://redis:6379/0

# --- SSE（浏览器访问宿主机 8010 时用 localhost）---
AGENT_SSE_PUBLIC_BASE=http://localhost:8010
SSE_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- PostgreSQL（Compose 服务 postgres）---
POSTGRES_USER=shark
POSTGRES_PASSWORD=shark
POSTGRES_DB=shark
POSTGRES_PORT_PUBLISH=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONNECT_TIMEOUT=10

# --- ClickHouse（Compose 服务 clickhouse；OLAP 访问日志）---
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=shark_obs
OBSERVABILITY_OLAP_MODE=analytics
OBSERVABILITY_MAX_EVENTS=200000
OBSERVABILITY_LLM_TIMEOUT_SEC=90
OBSERVABILITY_DISABLE_DETECTORS=false
CLICKHOUSE_STORE_RAW_EXCERPT=false

# --- 边缘 / Nginx 日志采集（go-log-collector 与 POST /api/edge/logs）---
# 与 web 的 SHARK_EDGE_TOKEN 一致；边缘容器用 SHARK_AIOPS_EDGE_TOKEN
SHARK_EDGE_TOKEN=local-dev-edge-token-change-me
# Compose → SHARK_AIOPS_STREAM_KEY：填 nginx-edge 合并多文件为一流；留空则按 access_*.json.log 文件名分 stream
LOG_COLLECTOR_STREAM_KEY=nginx-edge
# LOG_COLLECTOR_LOG_FORMAT=   # 可选；留空自动识别 .json.log

# --- Prometheus（接入线上时改为可路由 URL，留空则 SRE 工具不连 Prometheus）---
# 示例：https://prometheus.your-company.com
PROMETHEUS_URL=

# --- AI：DeepSeek（OpenAI 兼容接口，写入库内 AIConfig，容器启动时同步）---
# 在 https://platform.deepseek.com 创建 API Key
SHARK_AI_API_KEY=
SHARK_AI_PROVIDER=deepseek
SHARK_AI_API_BASE=https://api.deepseek.com/v1
SHARK_AI_MODEL=deepseek-chat
SHARK_AI_ENABLE=true

# --- AIOps 业务开关 ---
AIOPS_DEPLOYMENT_MODE=unspecified
AIOPS_DEFAULT_PLAYBOOK_NODE=default
AIOPS_AUTO_HEAL_CONFIDENCE=0.95

# --- 工单门禁（可选）---
SHARK_WORK_ORDER_GATE_ENABLED=false
SHARK_WORK_ORDER_GATE_ALLOW_SUPERUSER=true

# --- 可观测性规则阈值（可选，覆盖默认）---
# OBS_LATENCY_P99_WARN_SEC=1.5
# OBS_ERROR_RATE_WARN=0.05
# OBS_ERROR_MIN_SAMPLES=80
# OBS_TRAFFIC_DROP_RATIO=0.35
# OBS_TRAFFIC_DROP_MIN_BASELINE=50
