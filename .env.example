# =============================================================================
# Shark Platform — Docker Compose 本地联调（复制为 .env 后修改）
#   cp .env.example .env
#   # 必填：至少填写 SHARK_AI_API_KEY（DeepSeek）与 SHARK_EDGE_TOKEN（日志采集）
# =============================================================================

# --- Django ---
DJANGO_SECRET_KEY=dev-local-change-me-use-openssl-rand-hex-32-in-prod
DEBUG=True
ALLOWED_HOSTS=*
PUBLIC_URL=http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Redis / Celery（Compose 内服务名 redis，勿改主机名除非自定义网络）---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TIMEZONE=Asia/Shanghai
AGENT_EVENT_REDIS_URL=redis://redis:6379/0

# --- M2M 诊断执行器（主场景：Linux 主机 + Kubernetes；false/0 关闭）---
# AIOPS_M2M_ENABLE_PROMQL=true
# AIOPS_M2M_ENABLE_HTTPGET=true
# AIOPS_M2M_ENABLE_LOGMON=true
# AIOPS_M2M_ENABLE_KUBECTL=true
# AIOPS_M2M_ENABLE_HOST_CLI=true
# 以下为可选（默认不启用；Worker 装在 K8s 节点上排障时可打开 docker/crictl）
# AIOPS_M2M_ENABLE_DOCKER_CLI=false
# 多云只读 CLI（默认关；需在 Worker 配好凭证再设 true）
# AIOPS_M2M_ENABLE_CLOUD_CLI=false
# AIOPS_M2M_ENABLE_TERRAFORM=false
# AIOPS_M2M_CMD_TIMEOUT_SEC=120
# AIOPS_HTTPGET_TIMEOUT_SEC=15
# AIOPS_HTTPGET_MAX_BYTES=524288
# AIOPS_KUBECTL_PATH=kubectl

# （可选/遗留）若仓库内仍有基于 LangGraph StateGraph 的实验代码，可配置检查点后端。
# Celery「LangGraph 异步诊断」主路径已改为大模型 ReAct 循环，不依赖本项。
#LANGGRAPH_CHECKPOINT_BACKEND=memory

# --- SSE（浏览器访问宿主机 8010 时用 localhost）---
AGENT_SSE_PUBLIC_BASE=http://localhost:8010
SSE_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- PostgreSQL（Compose 服务 postgres）---
POSTGRES_USER=shark
POSTGRES_PASSWORD=shark
POSTGRES_DB=shark
POSTGRES_PORT_PUBLISH=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONNECT_TIMEOUT=10

# --- ClickHouse（Compose 服务 clickhouse；OLAP 访问日志）---
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
# 须与 compose 中 clickhouse 服务一致；CH 24+ 跨容器 HTTP 访问 default 用户需非空密码（默认 shark）
CLICKHOUSE_PASSWORD=shark
CLICKHOUSE_DATABASE=shark_obs
OBSERVABILITY_OLAP_MODE=analytics
OBSERVABILITY_MAX_EVENTS=200000
OBSERVABILITY_LLM_TIMEOUT_SEC=90
OBSERVABILITY_DISABLE_DETECTORS=false
CLICKHOUSE_STORE_RAW_EXCERPT=false

# --- GeoIP（GeoLite2 City，须遵守 MaxMind EULA）---
# 方式 A：仓库根目录放 GeoLite2-City.mmdb，compose 已挂载到容器 /app/state/（默认路径）
# 方式 B：镜像下载 .mmdb.gz（首次较慢，manage.py download_geoip 会打印进度）
# GEOIP_DATABASE_URL=https://cdn.jsdelivr.net/npm/geolite2-city/GeoLite2-City.mmdb.gz
# GEOIP_MMDB_HOST_FILE=./GeoLite2-City.mmdb   # 宿主机文件路径，可改绝对路径
# GEOIP_DATABASE_PATH=   # 默认 /app/state/GeoLite2-City.mmdb（Docker 内）

# --- 边缘 / Nginx 日志采集（go-log-collector 与 POST /api/edge/logs）---
# 与 web 的 SHARK_EDGE_TOKEN 一致；边缘容器用 SHARK_AIOPS_EDGE_TOKEN
SHARK_EDGE_TOKEN=local-dev-edge-token-change-me
# Compose → SHARK_AIOPS_STREAM_KEY：填 nginx-edge 合并多文件为一流；留空则按 access_*.json.log 文件名分 stream
LOG_COLLECTOR_STREAM_KEY=nginx-edge
# LOG_COLLECTOR_LOG_FORMAT=   # 可选；留空自动识别 .json.log

# --- Prometheus（仅用于「已产生事件后」SRE Agent 工具 query_prometheus 拉指标）---
# 不会轮询告警、不会替代 Alertmanager。示例：https://prometheus.your-company.com
PROMETHEUS_URL=
#
# 告警要进平台并触发分析，必须在 Alertmanager 配置 Webhook（与 PROMETHEUS_URL 是两件事）：
#   URL: https://<本服务公网或内网地址>/api/ai_ops/webhook/prometheus
#   方法: POST ；body 为 Alertmanager 标准 JSON（含 alerts[]）。
# 未配置该 Webhook 时，Prometheus/Alertmanager 里即使有 firing，本平台也不会收到，更无「主动感知」。

# --- AI：DeepSeek（OpenAI 兼容接口，写入库内 AIConfig，容器启动时同步）---
# 在 https://platform.deepseek.com 创建 API Key
SHARK_AI_API_KEY=
SHARK_AI_PROVIDER=deepseek
SHARK_AI_API_BASE=https://api.deepseek.com/v1
SHARK_AI_MODEL=deepseek-chat
SHARK_AI_ENABLE=true

# --- AIOps 业务开关 ---
AIOPS_DEPLOYMENT_MODE=unspecified
AIOPS_DEFAULT_PLAYBOOK_NODE=default
AIOPS_AUTO_HEAL_CONFIDENCE=0.95
# Webhook 触发 Celery 诊断后是否仍创建工单（false=仅报告/agent_trace）
AIOPS_AUTO_CREATE_TICKET_ON_ALERT=true
# Webhook 产生的 draft 工单是否自动变为待审批
AIOPS_ALERT_AUTO_SUBMIT_TICKET_PENDING=false
AIOPS_APPROVAL_POLICY_ENABLED=true
# 极低风险自动批准（info + 高置信 + 无危险命令模式）；生产请谨慎
AIOPS_APPROVAL_AUTO_LOW_RISK=false
# 出站通知 JSON Webhook（Slack/钉钉自定义机器人等）
# AIOPS_NOTIFY_WEBHOOK_URL=
AIOPS_NOTIFY_ON_RUN_START=false
AIOPS_NOTIFY_ON_TICKET_EVENTS=true
# 多集群 Prometheus：{"default":"https://prom/","east":"https://prom-east/"}
# AIOPS_PROMETHEUS_URL_BY_CLUSTER=
# 注入 Agent 的接入层日志 stream_key（空=自动选最近有数据的流）
# AIOPS_OBSERVABILITY_STREAM_KEY_FOR_INCIDENTS=
# 服务目录 JSON（列表或字典）
# AIOPS_SERVICE_CATALOG_JSON=[{"service":"checkout","owner":"team-a","cluster":"prod"}]
# 工单执行成功后可选校验 PromQL（空=跳过）
# AIOPS_POST_EXEC_VERIFY_PROMQL=up
# Alertmanager Webhook 鉴权（可并用）
# AIOPS_WEBHOOK_BEARER_TOKEN=
# AIOPS_WEBHOOK_HMAC_SECRET=   # 原始 body SHA256 hex，请求头 X-Shark-Signature 或 X-Hub-Signature-256: sha256=<hex>
# 仅 staff 可访问 AIOps 运维 API（事件列表/诊断/工单/大屏等）
AIOPS_OPS_REQUIRE_STAFF=false
# 可选 Vault（占位；密钥仍以环境变量为主）
# AIOPS_VAULT_ADDR=
# AIOPS_VAULT_SECRET_PATH=

# --- 工单门禁（可选）---
SHARK_WORK_ORDER_GATE_ENABLED=false
SHARK_WORK_ORDER_GATE_ALLOW_SUPERUSER=true

# --- 可观测性规则阈值（可选，覆盖默认）---
# OBS_LATENCY_P99_WARN_SEC=1.5
# OBS_ERROR_RATE_WARN=0.05
# OBS_ERROR_MIN_SAMPLES=80
# OBS_TRAFFIC_DROP_RATIO=0.35
# OBS_TRAFFIC_DROP_MIN_BASELINE=50
