DJANGO_SECRET_KEY=change-me
DEBUG=True
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
AGENT_SSE_PUBLIC_BASE=http://localhost:8010
SSE_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SHARK_EDGE_TOKEN=
PROMETHEUS_URL=

# 部署形态（可选）：kubernetes | hybrid | physical | unspecified
# 留空时：若在 K8s Pod 内（存在 KUBERNETES_SERVICE_HOST）则视为 kubernetes，否则 unspecified
# - kubernetes：中心在集群内，容器工作负载优先用 K8s API / 指标栈取数，一般不必为 Pod 再挂 go-log-collector
# - hybrid：云上/本地 K8s + 物理机/裸金属并存，边缘探针仅覆盖集群外资产
# - physical：以物理机/VM 为主，go-agent / go-log-collector 承担心跳与日志上报
AIOPS_DEPLOYMENT_MODE=

# 与边缘 go-agent 的 node_id 对齐；K8s 内执行 Playbook 可用固定逻辑节点名 + 集群内 controller 轮询
AIOPS_DEFAULT_PLAYBOOK_NODE=default
AIOPS_AUTO_HEAL_CONFIDENCE=0.95
